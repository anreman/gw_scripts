// ==UserScript==
// @name         GW Golf Timer
// @namespace    gwars
// @version      1.5
// @description  Показывает таймер бонуса гольфа и очки в верхней панели (без секунд)
// @match        https://www.gwars.io/*
// @grant        none
// @author       bazarov (assisted by AI)
// ==/UserScript==

(function () {
    'use strict';

    let remainingSeconds = 0;
    let golfPoints = localStorage.getItem('gwGolfPoints') || '?';

    function formatTime(sec) {
        const h = Math.floor(sec / 3600);
        const m = Math.floor((sec % 3600) / 60);

        return (
            String(h).padStart(2, '0') + ':' +
            String(m).padStart(2, '0')
        );
    }

    const hpElement = document.getElementById('hpheader');
    if (!hpElement) return;

    const style = document.createElement('style');
    style.innerHTML = `
    @keyframes gwBlink {
        0% { opacity: 1; }
        50% { opacity: 0.2; }
        100% { opacity: 1; }
    }

    #golfTimer.alert {
        color: red !important;
        animation: gwBlink 1s infinite;
        font-weight: bold;
    }
    `;
    document.head.appendChild(style);

    const golfSpan = document.createElement('span');
    golfSpan.id = 'golfTimer';
    golfSpan.style.cursor = 'pointer';

    golfSpan.addEventListener('click', function () {
        window.location.href = 'https://www.gwars.io/golf.php';
    });

    hpElement.insertAdjacentElement('afterend', golfSpan);

    function updateDisplay() {

        const expired = remainingSeconds <= 0;

        const value = !expired
            ? formatTime(remainingSeconds)
            : '00:00';

        golfSpan.innerHTML =
            ' | ⛳ <b>' +
            value +
            '</b> (' +
            golfPoints +
            ')';

        const inner = golfSpan.querySelector('b');

        if (expired) {
            inner.style.color = 'red';
            golfSpan.classList.add('alert');
        } else {
            inner.style.color = '#009900';
            golfSpan.classList.remove('alert');
        }
    }

    async function loadGolfTimer() {

        try {

            const response = await fetch(
                'https://www.gwars.io/golf.php',
                {
                    credentials: 'include'
                }
            );

            const buffer = await response.arrayBuffer();
            const decoder = new TextDecoder('windows-1251');
            const html = decoder.decode(buffer);

            // ⛳ Таймер HH:MM
            const timerMatch = html.match(
                /заканчивается через[\s\u00A0]*(\d{1,2})\s*:\s*(\d{2})/i
            );

            if (timerMatch) {

                const [, h, m] = timerMatch;

                remainingSeconds =
                    parseInt(h, 10) * 3600 +
                    parseInt(m, 10) * 60;

                if (isNaN(remainingSeconds)) {
                    remainingSeconds = 0;
                }

            } else {
                remainingSeconds = 0;
            }

            // 🎯 Очки
            const pointsMatch = html.match(
                /Накоплено очков:\s*(\d+)/i
            );

            if (pointsMatch) {
                golfPoints = pointsMatch[1];
                localStorage.setItem('gwGolfPoints', golfPoints);
            }

            updateDisplay();

        } catch (e) {

            console.log('GW Golf Timer error:', e);
        }
    }

    setInterval(() => {

        if (remainingSeconds > 0) {
            remainingSeconds--;
            updateDisplay();
        }

    }, 1000);

    setInterval(loadGolfTimer, 60000);

    loadGolfTimer();

})();
